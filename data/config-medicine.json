{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0.2,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": [
      "zh"
    ]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "disabled@example.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 15,
      "min_score": 120
    },
    "rss": [
      {
        "name": "NEJM",
        "url": "https://www.nejm.org/action/showFeed?type=etoc&feed=rss&jc=nejm",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "The Lancet",
        "url": "https://www.thelancet.com/rssfeed/lancet_current.xml",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "WHO News",
        "url": "https://www.who.int/rss-feeds/news-english.xml",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "BMJ Recent",
        "url": "https://www.bmj.com/rss/recent.xml",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Medical Xpress",
        "url": "https://medicalxpress.com/rss-feed/",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Nature Medicine",
        "url": "https://www.nature.com/nm.rss",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Nature Biotechnology",
        "url": "https://www.nature.com/nbt.rss",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Nature Medicine Research",
        "url": "https://www.nature.com/naturemedicine.rss",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "STAT News",
        "url": "https://www.statnews.com/feed/",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "CIDRAP",
        "url": "https://www.cidrap.umn.edu/rss.xml",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Fierce Biotech",
        "url": "https://www.fiercebiotech.com/rss/xml",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Fierce Pharma",
        "url": "https://www.fiercepharma.com/rss/xml",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "Pharmaceutical Technology",
        "url": "https://www.pharmaceutical-technology.com/feed/",
        "enabled": true,
        "category": "medicine"
      },
      {
        "name": "medRxiv",
        "url": "https://connect.medrxiv.org/medrxiv_xml.php?subject=all",
        "enabled": true,
        "category": "medicine"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "medicine",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 20
        },
        {
          "subreddit": "Health",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "biotech",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": [
        "All"
      ],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 0,
    "time_window_hours": 24,
    "max_items": 12,
    "category_groups": {},
    "default_group": "other",
    "default_group_limit": null
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {},
    "headers": "",
    "message_title": "医疗圈｜Horizon 每日速递 #{date}"
  }
}
