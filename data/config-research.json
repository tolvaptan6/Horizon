{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0.2,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": [
      "zh"
    ]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "disabled@example.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 15,
      "min_score": 120
    },
    "rss": [
      {
        "name": "Nature",
        "url": "https://www.nature.com/nature.rss",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "Science News",
        "url": "https://www.science.org/rss/news_current.xml",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "ScienceDaily",
        "url": "https://www.sciencedaily.com/rss/all.xml",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "PNAS Current Issue",
        "url": "https://www.pnas.org/rss/current.xml",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "Cell Current Issue",
        "url": "https://www.cell.com/cell/current.rss",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "Cell In Press",
        "url": "https://www.cell.com/cell/inpress.rss",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "PLOS Biology",
        "url": "https://journals.plos.org/plosbiology/feed/atom",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "Quanta Magazine",
        "url": "https://www.quantamagazine.org/feed/",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "MIT News Research",
        "url": "https://news.mit.edu/rss/topic/research",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "Phys.org",
        "url": "https://phys.org/rss-feed/",
        "enabled": true,
        "category": "research"
      },
      {
        "name": "bioRxiv",
        "url": "https://connect.biorxiv.org/biorxiv_xml.php?subject=all",
        "enabled": true,
        "category": "research"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "science",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 80
        },
        {
          "subreddit": "AskScience",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "Futurology",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "Jupyter Notebook"
      ],
      "keywords": [
        "science",
        "research",
        "bio",
        "medical",
        "ai"
      ],
      "min_stars": 20,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 0,
    "time_window_hours": 24,
    "max_items": 12,
    "category_groups": {},
    "default_group": "other",
    "default_group_limit": null
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {},
    "headers": "",
    "message_title": "科研圈｜Horizon 每日速递 #{date}"
  }
}
